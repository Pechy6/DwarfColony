@model NeedsViewModel

@{
    ViewData["Title"] = "Dwarf needs Management";
}
<form asp-action="Sleep">
    @Html.AntiForgeryToken()

    <div class="table-responsive-md">
        <table class="table table-dark table-hover">
            <thead class="table-danger">
            <tr>
                <th>Name</th>
                <th>Age</th>
                <th>Energy</th>
                <th>Hunger</th>
                <th>Thirst</th>
                <th>Job</th>
                <th>Status</th>
                <th>State</th>
                <th>Set sleep</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var dwarf in Model.Dwarves)
            {
                <tr>
                    <td><a asp-controller="Dwarves" asp-action="Details" asp-route-id="@dwarf.Id"
                           class="table-text">@dwarf.Name</a></td>
                    <td>@dwarf.Age</td>
                    <td>@dwarf.Energy</td>
                    <td>@dwarf.Hunger</td>
                    <td>@dwarf.Thirst</td>
                    <td>@dwarf.Job</td>
                    <td>@dwarf.Status</td>
                    <td>@dwarf.State</td>
                    <td>
                        @if (dwarf.CanSleep)
                        {
                            <input type="checkbox" name="SelectedDwarvesIds" value="@dwarf.Id"/>
                        }
                        else
                        {
                            <span class="text-danger">Cant sleep</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        
        <div class="form-group mb-3">
            <label asp-for="TimeToSleep"></label>
            <input asp-for="TimeToSleep" class="form-control"/>
            <span asp-validation-for="TimeToSleep" class="text-danger"></span>
        </div>
        
        <button type="submit" class="btn btn-primary">Sleep</button>
    </div>
</form>