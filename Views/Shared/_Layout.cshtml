<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - DwarfColony</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark">
        <a class="navbar-brand" href="#">
            <img src="~/images/icon.png" srcset="images/icon.png 1x, images/iconForRetina.png 2x"
                 class="rounded-circle avatar ms-3" alt="icon">
        </a>
        <ul class="navbar-nav">
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="nav-link">Home</a></li>
            <li class="nav-item"><a asp-controller="Dwarves" asp-action="Index" class="nav-link">Dwarf Base</a></li>
        </ul>
    </nav>
</header>
<div class="container">
    <article>
        <header>
            <h1>@ViewData["Title"]</h1>
        </header>
        <section>
            @RenderBody()
        </section>
    </article>
</div>

<footer class="border-top footer text-muted">
    <div class="container">
        HedgeHog6 &copy; @DateTime.Now.Year
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
