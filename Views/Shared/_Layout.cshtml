
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - DwarfColony</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
</head>
<body class="d-flex flex-column min-vh-100">
<header>
    <nav class="navbar navbar-expand-md navbar-dark bg-dark">
        <a class="navbar-brand" href="#">
            <img src="~/images/icon.png" srcset="images/icon.png 1x, images/iconForRetina.png 2x"
                 class="rounded-circle avatar ms-3" alt="icon">
        </a>
        <ul class="navbar-nav">
            <li class="nav-item"><a asp-controller="Home" asp-action="Index" class="nav-link">Home</a></li>
            <li class="nav-item"><a asp-controller="Dwarves" asp-action="Index" class="nav-link">Dwarf Base</a></li>
        </ul>
        @await Component.InvokeAsync("NavbarStats")
    </nav>
    <div class="card bg-danger">
        <div class="card-body">
            <h5 class="card-title">Work in Progress</h5>
            <p class="card-text">
                This application is currently under development. 
                You can already hire dwarves, manage their jobs, and track basic resources. 
                More features and improvements are <b>coming soon</b>!
            </p>
        </div>
    </div>
</header>
<div class="container mt-4">
    <article class="flex-grow-1">
        <header>
            <h1>@ViewData["Title"]</h1>
        </header>
        <section>
            <div class="card p-4 bg-dark text-white">
            @RenderBody()
            </div>
        </section>
    </article>
</div>

<footer class="footer bg-dark text-white mt-auto">
    <div class="container">
HedgeHog6 &copy; @DateTime.Now.Year
    </div>
</footer>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
