@using DwarfColony.Models.Entities
@model DwarfColony.Models.ViewModels.EditDwarfModel
@{
    ViewData["Title"] = "Edit @Model.Name";
}

<h1>Dwarf: <b>@Model.Name</b></h1>
<h3>Job: <b>@Model.Job</b></h3>
<form asp-action="Edit">
    <input type="hidden" asp-for="Id"/>
    
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control">
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Job" class="form-label"></label>
        <select asp-for="Job" asp-items="Html.GetEnumSelectList<DwarfJob>()" class="form-control"></select>
    </div>

    <input type="submit" value="Save" class="btn btn-primary">
</form>
